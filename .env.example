# ---------------------------------------------------------
# BusinessHub ERP - Environment Variables (template)
# Copy this file to `.env` and fill in real values.
# Never commit your actual `.env` file.
# ---------------------------------------------------------

# Runtime environment: development | production | test
NODE_ENV=development

# Backend server port
PORT=5000

# Allowed CORS origin ("*" for any, or a specific origin like http://localhost:5173)
CORS_ORIGIN=*

# Microsoft SQL Server connection
DB_HOST=localhost
DB_PORT=1433
DB_NAME=businesshub
DB_USER=sa
# SQL Server enforces a strong SA password (8+ chars, upper/lower/digit/symbol).
DB_PASSWORD=Your_Strong_Passw0rd!

# Connection options
DB_ENCRYPT=false                   # true for Azure SQL / TLS in production
DB_TRUST_SERVER_CERTIFICATE=true   # true for local/dev self-signed certs
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_CONNECTION_TIMEOUT_MS=15000

# Authentication
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10
